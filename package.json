{
  "name": "dataguard-ai",
  "displayName": "DataGuard AI",
  "description": "AI-powered dataset health analysis for Data Scientists",
  "publisher": "Sachin213-stack",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sachin213-stack/DataGuard.git"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Data Science",
    "Machine Learning"
  ],
  "keywords": [
    "data",
    "csv",
    "dataset",
    "data quality",
    "pandas",
    "machine learning",
    "data science",
    "analysis"
  ],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:python",
    "onLanguage:csv",
    "onLanguage:json",
    "onCommand:dataguard.analyzeDataset",
    "onCommand:dataguard.browseAndAnalyze",
    "workspaceContains:**/*.csv",
    "workspaceContains:**/*.parquet",
    "workspaceContains:**/*.json",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dataguard.analyzeDataset",
        "title": "Analyze Dataset Health",
        "category": "DataGuard"
      },
      {
        "command": "dataguard.browseAndAnalyze",
        "title": "Browse & Analyze Any Dataset...",
        "category": "DataGuard"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dataguard",
          "title": "DataGuard",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "dataguard": [
        {
          "id": "dataguardView",
          "name": "DataGuard"
        }
      ]
    },
    "configuration": {
      "title": "DataGuard",
      "properties": {
        "dataguard.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Gemini API key for AI-powered summaries"
        },
        "dataguard.autoAnalyzeOnCreate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically prompt to analyze when new CSV/Parquet/JSON files are created"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "jest",
    "test:python": "python -m pytest sidecar/tests/ -v"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/*.test.ts"],
    "moduleNameMapper": {
      "^vscode$": "<rootDir>/src/__mocks__/vscode.ts"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "tsconfig": {
          "strict": true,
          "esModuleInterop": true,
          "module": "commonjs",
          "target": "ES2020",
          "skipLibCheck": true
        }
      }]
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.0"
  }
}
